{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kaeya",
  "version": "0.1.0",
  "identifier": "com.konx.assistant",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "url": "index.html",
        "title": "Kaeya",
        "width": 960,
        "height": 680,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "center": true,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "shadow": false
      },
      {
        "label": "orb",
        "url": "orb.html",
        "title": "Kaeya",
        "width": 120,
        "height": 120,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": true,
        "shadow": false,
        "x": 1780,
        "y": 460
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["kaeya"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
